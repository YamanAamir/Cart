generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admins {
  id             Int         @id @default(autoincrement())
  fullName       String      @db.VarChar(255)
  email          String      @unique(map: "email") @db.VarChar(255)
  password       String      @db.VarChar(255)
  createdAt      DateTime?   @default(now()) @db.DateTime(0)
  cloudinaryId   String?     @db.VarChar(255)
  isAccess       AccessLevel @default(LOW)
  isAdmin        Boolean     @default(true)
  isSuper        Boolean     @default(false)
  profilePicture String?     @db.Text
  updatedAt      DateTime?   @updatedAt
  isActive       Boolean     @default(true)
}

model customers {
  id                    Int                    @id @default(autoincrement())
  fullName              String                 @db.VarChar(255)
  email                 String                 @unique(map: "email") @db.VarChar(255)
  password              String                 @db.VarChar(255)
  createdAt             DateTime?              @default(now()) @db.DateTime(0)
  updatedAt             DateTime?              @updatedAt
  isActive              Boolean                @default(true)
  billingCity           String
  billingCountry        String
  billingState          String
  billingStreet         String
  billingZip            String
  commercialCity        String
  commercialCountry     String
  commercialState       String
  commercialStreet      String
  commercialZip         String
  order                 Order[]
  savedBuilds           savedBuilds[]
  warranties            Warranty[]
  passwordResetAttempts PasswordResetAttempt[]
  verificationCodes     VerificationCode[]
}

model PasswordResetAttempt {
  id         Int      @id @default(autoincrement())
  customerId Int
  createdAt  DateTime @default(now())

  customer customers @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model VerificationCode {
  id         Int      @id @default(autoincrement())
  customerId Int
  phone      String?
  code       String
  isForReset Boolean  @default(false)
  expiry     DateTime
  createdAt  DateTime @default(now())

  customer customers @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model savedBuilds {
  id         Int       @id @default(autoincrement())
  customerId Int
  productIds Json
  customer   customers @relation(fields: [customerId], references: [id])
}

model Product {
  id           Int         @id @default(autoincrement())
  name         String
  stock        Int         @default(0)
  salePrice    Decimal     @db.Decimal(10, 2)
  regularPrice Decimal     @db.Decimal(10, 2)
  color        String? // Only used for Enclosure products
  imageOne     String?
  imgAltOne    String?
  imageTwo     String?
  imgAltTwo    String?
  imageThree   String?
  imgAltThree  String?
  imageFour    String?
  imgAltFour   String?
  brandId      Int
  modelId      Int
  typeId       Int
  orderItems   OrderItem[]
  brand        Brand       @relation(fields: [brandId], references: [id])
  model        Model       @relation(fields: [modelId], references: [id])
  productType  ProductType @relation(fields: [typeId], references: [id])
  weightLb     Decimal     @db.Decimal(8, 2) // e.g. 2.50

  lengthIn       Decimal  @db.Decimal(8, 2)
  widthIn        Decimal  @db.Decimal(8, 2)
  heightIn       Decimal  @db.Decimal(8, 2)
  description    String
  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  slug           String?  @unique @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Composite unique key for upsert
  @@unique([name, brandId, modelId, typeId, color])
}

model ProductType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Model {
  id        Int       @id @default(autoincrement())
  name      String
  brandId   Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  brand     Brand     @relation(fields: [brandId], references: [id])
  products  Product[]

  seoTitle       String? @db.VarChar(255)
  seoDescription String? @db.Text
  seoKeywords    String? @db.Text
  slug           String? @unique @db.VarChar(255)

  @@unique([name, brandId])
  @@index([brandId], map: "Model_brandId_fkey")
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  path      String?
  logo      String?
  imgAlt    String?
  models    Model[]
  products  Product[]

  seoTitle       String? @db.VarChar(255)
  seoDescription String? @db.Text
  seoKeywords    String? @db.Text
  slug           String? @unique @db.VarChar(255)
}

model DealerRegistration {
  id                     Int          @id @default(autoincrement())
  companyName            String
  title                  String?
  firstName              String
  lastName               String
  email                  String       @unique
  phone                  String
  mobile                 String?
  fax                    String?
  billingStreet          String
  billingCity            String
  billingState           String
  billingZip             String
  billingCountry         String
  commercialStreet       String
  commercialCity         String
  commercialState        String
  commercialZip          String
  commercialCountry      String
  hasShowroom            String
  EIN                    String?
  interestedBrands       Json
  sellBrands             Json
  authorizedDealer       Json
  createdAt              DateTime     @default(now())
  isApproved             Boolean?     @default(false)
  status                 DealerStatus @default(pending)
  authorizedDealersOther String?
  resaleCertificate      String?
  sellBrandsOther        String?
}

model Order {
  id             Int         @id @default(autoincrement())
  customerId     Int
  status         OrderStatus @default(PENDING)
  totalAmount    Decimal     @db.Decimal(10, 2)
  shipmentCost   Decimal?    @db.Decimal(10, 2)
  shipmentStatus String?     @default("UNKNOWN") @db.VarChar(100)
  trackingNumber String?     @db.VarChar(255)
  labelUrl       String?     @db.Text
  carrier        String?     @db.VarChar(100)
  serviceLevel   String?     @db.VarChar(100)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  customer       customers   @relation(fields: [customerId], references: [id])
  items          OrderItem[]

  @@index([customerId])
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  productId    Int
  quantity     Int
  priceAtOrder Decimal @db.Decimal(10, 2)
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Warranty {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  address      String    @db.VarChar(255)
  email        String    @db.VarChar(255)
  phone        String?   @db.VarChar(50)
  model        String    @db.VarChar(255)
  purchase     DateTime
  discount     Boolean   @default(false)
  registeredAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime? @updatedAt

  // Relation to customer
  customerId Int?
  customer   customers? @relation(fields: [customerId], references: [id])

  @@index([email])
}

model StatsCards {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  value     String    @db.VarChar(255)
  link      String?   @db.VarChar(255)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
}

model HeroSection {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?   @db.Text
  imageUrl    String?   @db.Text
  imgAlt      String?   @db.VarChar(255)
  ctaTextOne  String?   @db.VarChar(255)
  ctaLinkOne  String?   @db.VarChar(255)
  ctaTextTwo  String?   @db.VarChar(255)
  ctaLinkTwo  String?   @db.VarChar(255)
  isActive    Boolean   @default(true)
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AccessLevel {
  LOW
  MEDIUM
  HIGH
}

enum DealerStatus {
  pending
  approved
  rejected
}

model PageSeo {
  id             Int      @id @default(autoincrement())
  pageName       String   @unique @db.VarChar(100) // e.g., 'home', 'shop', 'contact'
  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.Text
  seoKeywords    String?  @db.Text
  slug           String?  @unique @db.VarChar(255)
  updatedAt      DateTime @updatedAt
}
